# --- Python ---
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# --- Raw upstream data (NOT committed; see NOTICE) ---
# HYDE grids are large and range-fetched; Cliopatria / Natural Earth are vendored locally.
# The folder's README (what to stage) IS tracked; the data itself is not.
data/raw/*
!data/raw/README.md
*.asc
*.zip
*.tif
*.tiff

# --- Processed outputs ARE tracked (small, derived) ---
# data/processed/        <- intentionally committed
# web/*.js               <- emitted facts/totals/polities, committed

# --- OS / editor cruft ---
.DS_Store
Thumbs.db
.vscode/
.idea/

# --- Vercel ---
.vercel/

# --- Local browser-verification tooling (not part of the project) ---
node_modules/
package.json
package-lock.json
.pwlibs/
